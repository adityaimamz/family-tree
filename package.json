{
  "name": "warisan-ai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite --host 127.0.0.1",
    "dev:backend": "tsx --env-file=.env server/index.ts",
    "build": "npx prisma generate && tsc -b && tsc -p tsconfig.server.json && vite build",
    "start": "node build/server/index.js",
    "preview": "vite preview --host 127.0.0.1",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@neondatabase/neon-js": "^0.5.0-beta",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@uploadthing/react": "^7.3.3",
    "@vitejs/plugin-react": "^5.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "framer-motion": "^12.23.24",
    "jose": "^6.1.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "sharp": "^0.34.5",
    "uploadthing": "^7.7.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "fast-check": "^4.7.0",
    "postcss": "^8.4.49",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "effect": "3.20.0",
    "@hono/node-server": "1.19.13",
    "better-auth": "^1.6.2",
    "hono": "^4.12.18",
    "fast-uri": "^3.1.2"
  }
}
